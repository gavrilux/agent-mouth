{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": ["**/dist/**", "**/node_modules/**"]
  },
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": { "noNonNullAssertion": "off" }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "overrides": [
    {
      "include": ["**/*.test.ts"],
      "linter": {
        "rules": {
          "suspicious": { "noExplicitAny": "off", "noImplicitAnyLet": "off" },
          "performance": { "noDelete": "off" },
          "style": { "noUnusedTemplateLiteral": "off", "useTemplate": "off" },
          "complexity": { "useLiteralKeys": "off" },
          "correctness": { "noUnnecessaryContinue": "off" }
        }
      }
    }
  ]
}
